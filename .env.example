# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Universal MCP Gateway

# ──────────────────────────────────────────────
# Database — MongoDB Atlas
# ──────────────────────────────────────────────
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50

# ──────────────────────────────────────────────
# Cache — Upstash Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://<default>:<password>@<endpoint>.upstash.io:6379

# ──────────────────────────────────────────────
# Object Storage — Cloudflare R2
# ──────────────────────────────────────────────
R2_ACCESS_KEY_ID=<access-key>
R2_SECRET_ACCESS_KEY=<secret-key>
R2_BUCKET_NAME=<bucket-name>
R2_ACCOUNT_ID=<account-id>
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ──────────────────────────────────────────────
# AI — OpenRouter
# ──────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-<key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERRER=https://github.com/universal-mcp-gateway

# ──────────────────────────────────────────────
# Authentication — Better Auth
# ──────────────────────────────────────────────
BETTER_AUTH_SECRET=<generate-with-pnpm dlx better-auth@latest generate>
BETTER_AUTH_URL=http://localhost:3000

AUTH_GOOGLE_ID=<google-client-id>
AUTH_GOOGLE_SECRET=<google-client-secret>
AUTH_GITHUB_ID=<github-client-id>
AUTH_GITHUB_SECRET=<github-client-secret>

# ──────────────────────────────────────────────
# Monitoring — Sentry
# ──────────────────────────────────────────────
SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project>
SENTRY_ENVIRONMENT=development

# ──────────────────────────────────────────────
# Queue — Inngest
# ──────────────────────────────────────────────
INNGEST_EVENT_KEY=<event-key>
INNGEST_SIGNING_KEY=<signing-key>
INNGEST_APP_ID=universal-mcp-gateway

# ──────────────────────────────────────────────
# Encryption — AES-256-GCM
# ──────────────────────────────────────────────
ENCRYPTION_KEY=<generate-with-pnpm exec tsx -e "console.log(require('crypto').randomBytes(32).toString('base64'))">

# ──────────────────────────────────────────────
# Logging — Pino
# ──────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
